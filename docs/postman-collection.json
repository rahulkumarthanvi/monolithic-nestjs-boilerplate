{
  "info": {
    "name": "Nest Monolith Boilerplate",
    "_postman_id": "c1b7e2e4-0000-0000-0000-000000000000",
    "description": "Postman collection for production-ready monolithic NestJS boilerplate. Import this file in Postman and set collection variables: base_url, accessToken, refreshToken, deviceId, userId.",
