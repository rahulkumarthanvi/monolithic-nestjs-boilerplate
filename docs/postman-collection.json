				{
					"name": "login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let responseData = pm.response.json();",
									"",
									"let accessToken = responseData?.data?.accessToken;",
									"let refreshToken = responseData?.data?.refreshToken;",
									"let role = responseData?.data?.user?.roleId;",
									"",
									"// Store common tokens",
									"if (accessToken) {",
									"    pm.environment.set(\"accessToken\", accessToken);",
									"}",
									"",
									"if (refreshToken) {",
									"    pm.environment.set(\"refreshToken\", refreshToken);",
									"}",
									"",
									"// Store role-based token in camelCase",
									"if (role && accessToken) {",
									"    let camelCaseKey = role",
									"        .toLowerCase()",
									"        .split(\"_\")",
									"        .map((word, index) =>",
									"            index === 0",
									"                ? word",
									"                : word.charAt(0).toUpperCase() + word.slice(1)",
									"        )",
									"        .join(\"\") + \"Token\";",
									"",
									"    pm.environment.set(camelCaseKey, accessToken);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
